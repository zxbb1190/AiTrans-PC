{
  "name": "desktop-screenshot-translate-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Windows MVP Electron shell for ArchSync screenshot translation.",
  "main": "main.js",
  "dependencies": {
    "vue": "^3.5.13"
  },
  "scripts": {
    "doctor": "node scripts/doctor.js",
    "release:check": "node scripts/release-check.js",
    "stage:tesseract": "node scripts/stage-tesseract.js",
    "panel:build": "vite build --config vite.panel.config.mjs",
    "start": "electron .",
    "dev": "npm run panel:build && electron .",
    "dev:doctor": "npm run doctor && npm run dev",
    "pack:win": "npm run panel:build && npm run release:check && electron-builder --win portable",
    "dist:win": "npm run panel:build && npm run release:check && electron-builder --win nsis",
    "check": "node --check main.js && node --check preload.js && node --check lib/project-config.js && node --check lib/window-state.js && node --check lib/local-pipeline.js && node --check lib/provider-runtime.js && node --check lib/runtime-overrides.js && node --check lib/ocr-adapters.js && node --check lib/translation-adapters.js && node --check renderer/overlay/overlay.js && node --check scripts/doctor.js && node --check scripts/release-check.js && node --check scripts/stage-tesseract.js && vite build --config vite.panel.config.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.archsync.desktop_screenshot_translate",
    "productName": "ArchSync Screenshot Translate",
    "artifactName": "desktop-screenshot-translate-${version}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*",
      "lib/**/*",
      "renderer/overlay/**/*",
      "renderer/panel-dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../../projects/desktop_screenshot_translate/generated",
        "to": "project-generated",
        "filter": [
          "product_spec.json",
          "generation_manifest.json",
          "implementation_bundle.py"
        ]
      },
      {
        "from": "vendor/tesseract",
        "to": "tesseract",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "config",
        "to": "config",
        "filter": [
          "runtime-overrides.example.json"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ArchSync Screenshot Translate",
      "runAfterFinish": true
    }
  }
}
