{
  "project": {
    "project_id": "desktop_screenshot_translate",
    "template": "desktop_screenshot_translate",
    "display_name": "AiTrans 截图翻译",
    "description": "An AI-style desktop translation assistant that turns screenshots and text into a local conversation thread.",
    "version": "0.2.2"
  },
  "framework": {
    "frontend": "framework/frontend/L2-M0-前端框架标准模块.md",
    "domain": "framework/aitrans/L3-M0-桌面截图翻译框架.md",
    "runtime": "framework/runtime_env/L0-M0-运行环境识别模块.md",
    "preset": "desktop_capture_translate_panel"
  },
  "surface": {
    "shell": "tray_hotkey_capture_overlay",
    "layout_variant": "single_result_floating_panel",
    "entry_mode": "tray_and_shortcut",
    "result_mode": "floating_panel",
    "density": "comfortable",
    "copy": {
      "app_name": "AiTrans 截图翻译",
      "tagline": "截一块，立刻看到译文",
      "capture_hint": "按下截图快捷键后拖选区域，松开即可开始识别和翻译；按 Enter 或双击可直接整屏截图。",
      "empty_title": "准备截图",
      "empty_copy": "从托盘或全局快捷键开始，拖选一个区域后自动输出译文。",
      "processing_title": "正在翻译",
      "processing_copy": "正在识别文字并生成译文，结果会在悬浮面板中出现。"
    }
  },
  "visual": {
    "brand": "AiTrans",
    "accent": "#0f766e",
    "surface_preset": "mist",
    "radius_scale": "lg",
    "shadow_level": "md",
    "font_scale": "md"
  },
  "a11y": {
    "reading_order": [
      "tray_entry",
      "capture_overlay",
      "result_actions",
      "source_text",
      "translated_text"
    ],
    "keyboard_nav": [
      "start-capture",
      "cancel-capture",
      "copy-translation",
      "retry-translation",
      "close-panel"
    ],
    "announcements": [
      "capture started",
      "capture cancelled",
      "translation ready",
      "translation failed"
    ]
  },
  "desktop": {
    "platforms": [
      "windows",
      "macos"
    ],
    "entry_points": [
      "tray",
      "global_shortcut"
    ],
    "single_instance": true,
    "permissions": [
      "screen_recording",
      "accessibility"
    ],
    "degrade_policy": "permission_guided_downgrade",
    "hotkey_behavior": "rebindable",
    "window_strategy": "hidden_shell_plus_overlay_panel",
    "focus_restore": true
  },
  "capture": {
    "modes": [
      "region",
      "fullscreen"
    ],
    "selection_shape": "rectangle",
    "cancel_methods": [
      "esc",
      "right_click"
    ],
    "include_cursor": false,
    "multi_display": true,
    "high_dpi": true,
    "session_policy": "one_capture_one_session",
    "image_format": "png_bitmap"
  },
  "pipeline": {
    "source_languages": [
      "auto",
      "zh",
      "en",
      "ja"
    ],
    "target_language": "zh-Hans",
    "deliverables": [
      "source_text",
      "translated_text",
      "source_language",
      "stage_status",
      "error_origin"
    ],
    "fallback_policy": "retry_then_switch_provider",
    "timeout_budget_ms": 5000,
    "latency_budget_p95_ms": 4500,
    "ocr_confidence_visible": false
  },
  "presentation": {
    "panel_variant": "floating_compact_dual_column",
    "show_source_text": true,
    "show_translated_text": true,
    "show_status": true,
    "show_error_reason": true,
    "default_pinned": false,
    "actions": [
      "copy_translation",
      "retry_translation",
      "close_panel",
      "recapture"
    ],
    "auto_hide": "manual_only",
    "copy": {
      "copy_success": "译文已复制",
      "retry_label": "重试翻译",
      "close_label": "关闭",
      "recapture_label": "重新截图",
      "failure_title": "翻译失败",
      "empty_translation": "未识别到可翻译文本"
    }
  },
  "governance": {
    "event_scope": [
      "capture",
      "ocr",
      "translation",
      "render",
      "release"
    ],
    "audit_fields": [
      "capture_session_id",
      "task_id",
      "provider",
      "result_state"
    ],
    "privacy_mode": "sensitive_text_not_persisted_by_default",
    "update_channel": "stable",
    "compat_matrix": [
      "windows-11+",
      "macos-13+"
    ],
    "offline_policy": "allow_local_capture_and_local_ocr_only",
    "capture_p95_ms": 120,
    "ocr_p95_ms": 2200,
    "translation_p95_ms": 1800,
    "render_p95_ms": 300
  }
}
